<Window x:Class="ImeLocker.UI.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:config="clr-namespace:ImeLocker.Config"
        xmlns:ui="clr-namespace:ImeLocker.UI"
        Title="ImeLocker 配置"
        Icon="/app.ico"
        Width="600" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ui:HklToConversionModesConverter x:Key="HklToConversionModesConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top section: Default preset -->
        <GroupBox Grid.Row="0" Header="默认切换方案" Margin="0,0,0,8">
            <StackPanel Margin="8">
                <TextBlock Text="未显式配置的程序均采用此方案" Foreground="Gray" FontSize="11" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="默认模式：" VerticalAlignment="Center" Margin="0,0,8,4"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                              SelectedValue="{Binding DefaultMode}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="预设 (Preset)" Tag="{x:Static config:SwitchMode.Preset}"/>
                        <ComboBoxItem Content="记忆 (Remember)" Tag="{x:Static config:SwitchMode.Remember}"/>
                    </ComboBox>

                    <!-- Mode description -->
                    <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Gray" FontSize="11" Margin="0,0,0,6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="激活窗口时切换为下列预设"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DefaultMode}" Value="{x:Static config:SwitchMode.Remember}">
                                        <Setter Property="Text" Value="激活窗口，切换为离开时的输入法"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Keyboard layout & conversion mode: visible only in Preset mode -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="键盘布局：" VerticalAlignment="Center" Margin="0,0,8,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DefaultMode}" Value="{x:Static config:SwitchMode.Remember}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,4"
                              ItemsSource="{Binding InstalledKeyboardLayouts}"
                              SelectedValue="{Binding PresetKeyboardLayout}"
                              SelectedValuePath="HklHex"
                              DisplayMemberPath="DisplayName">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DefaultMode}" Value="{x:Static config:SwitchMode.Remember}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="转换模式：" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DefaultMode}" Value="{x:Static config:SwitchMode.Remember}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ComboBox Grid.Row="3" Grid.Column="1"
                              ItemsSource="{Binding AvailableConversionModes}"
                              SelectedValue="{Binding PresetConversionMode}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DefaultMode}" Value="{x:Static config:SwitchMode.Remember}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Main section: Groups -->
        <GroupBox Grid.Row="1" Header="方案分组" Margin="0,0,0,8">
            <Grid Margin="8" MinHeight="280">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Group list -->
                <DockPanel Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="添加" Command="{Binding AddGroupCommand}" Padding="8,2" Margin="0,0,4,0"/>
                        <Button Content="移除" Command="{Binding RemoveGroupCommand}" Padding="8,2"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup}"
                             DisplayMemberPath="Name"/>
                </DockPanel>

                <!-- Group detail -->
                <StackPanel Grid.Column="1" DataContext="{Binding SelectedGroup}" IsEnabled="{Binding Path=DataContext.SelectedGroup, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Null}}">
                    <Grid DataContext="{Binding DataContext.SelectedGroup, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="分组名称：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="切换模式：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox Width="200"
                                      SelectedValue="{Binding Mode}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="预设 (Preset)" Tag="{x:Static config:SwitchMode.Preset}"/>
                                <ComboBoxItem Content="记忆 (Remember)" Tag="{x:Static config:SwitchMode.Remember}"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Keyboard layout: visible only in Preset mode -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Mode}" Value="{x:Static config:SwitchMode.Remember}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="键盘布局：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox Width="200"
                                      ItemsSource="{Binding DataContext.InstalledKeyboardLayouts, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedValue="{Binding Preset.KeyboardLayout}"
                                      SelectedValuePath="HklHex"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>

                        <!-- Conversion mode: visible only in Preset mode -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,4">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Mode}" Value="{x:Static config:SwitchMode.Remember}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="转换模式：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox Width="200"
                                      ItemsSource="{Binding Preset.KeyboardLayout, Converter={StaticResource HklToConversionModesConverter}}"
                                      SelectedValue="{Binding Preset.ConversionMode}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4" Text="应用列表：" Margin="0,8,0,4"/>

                        <DockPanel Grid.Row="5">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="扫描进程" Command="{Binding DataContext.ScanProcessesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        IsEnabled="{Binding DataContext.IsScanning, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static ui:InverseBoolConverter.Instance}, FallbackValue=True}"
                                        Padding="8,2" Margin="0,0,4,0"/>
                                <TextBlock Text="扫描中..." VerticalAlignment="Center" Margin="0,0,4,0"
                                           Visibility="{Binding DataContext.IsScanning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                                <ComboBox ItemsSource="{Binding DataContext.ScannedProcesses, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DataContext.SelectedScannedProcess, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Width="150" Margin="0,0,4,0"/>
                                <Button Content="添加应用" Command="{Binding DataContext.AddAppToGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}" Padding="8,2" Margin="0,0,4,0"/>
                                <Button Content="移除" Command="{Binding DataContext.RemoveAppFromGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}" Padding="8,2"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Apps}"
                                     SelectedItem="{Binding DataContext.SelectedApp, RelativeSource={RelativeSource AncestorType=Window}}"
                                     MinHeight="80">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProcessName, Converter={x:Static ui:ProcessNameToDisplayConverter.Instance}}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" Command="{Binding SaveCommand}" Padding="16,4" Margin="0,0,8,0"/>
            <Button Content="关闭" Click="OnCloseClick" Padding="16,4"/>
        </StackPanel>
    </Grid>
</Window>
